cat > .gitignore <<'EOF'
wp-config.php
.env
.env.*
.htaccess

wp-content/uploads/
wordpress/wp-content/uploads/

wp-content/cache/
wordpress/wp-content/cache/
wp-content/wflogs/
wordpress/wp-content/wflogs/

*.zip
*.tar.gz
*.sql
backup/
backups/

node_modules/
.next/
dist/
build/

*.log
.DS_Store
EOF

.builder/config/data.json

# Python
venv/
__pycache__/
*.pyc
*.pyo

# Credentials
*.json
scripts/yatezzitos_crawler/logs/
.vscode/

# MCP env files (raiz del repo)
.env.ghl-mcp
.env.wp-mcp-remote

# Config generado por scripts/sync-mcp.py (paths absolutos, no portable)
/.mcp.json
/.mcp.json.bak.*

# MCP Integrations — allow tracked configs, keep real secrets out
!integrations/**/*.json
integrations/wp-mcp/wp-sites.json
integrations/mcp-gsc/client_secrets.json
integrations/mcp-gsc/token.json
integrations/mcp-gsc/service_account_credentials.json
integrations/**/.venv/
integrations/ghl-mcp/dist/
integrations/ghl-mcp/coverage/
!integrations/**/.env.example
!integrations/**/*.example
