cat > .gitignore <<'EOF'
wp-config.php
.env
.env.*
.htaccess

wp-content/uploads/
wordpress/wp-content/uploads/

wp-content/cache/
wordpress/wp-content/cache/
wp-content/wflogs/
wordpress/wp-content/wflogs/

*.zip
*.tar.gz
*.sql
backup/
backups/

node_modules/
.next/
dist/
build/

*.log
.DS_Store
EOF
