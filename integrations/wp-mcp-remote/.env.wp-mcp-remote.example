# Template de credenciales para @automattic/mcp-wordpress-remote.
# Copiar a la raiz del repo como `.env.wp-mcp-remote` (gitignored) y rellenar.
#
#   cp integrations/wp-mcp-remote/.env.wp-mcp-remote.example .env.wp-mcp-remote
#
# Luego editar .env.wp-mcp-remote con las credenciales reales.
# La Application Password se genera en yatezzitos.com/wp-admin -> Profile -> Application Passwords.

# IMPORTANTE: WP_API_PASSWORD DEBE ir entre comillas dobles porque la
# Application Password de WordPress contiene espacios. Sin comillas, bash
# interpreta las palabras despues del primer espacio como comandos y falla
# con "orden no encontrada".

WP_API_URL="https://yatezzitos.com"
WP_API_USERNAME="seoclaude"
WP_API_PASSWORD="xxxx xxxx xxxx xxxx xxxx xxxx"
LOG_FILE="/tmp/wordpress-mcp-yatezzitos.log"
